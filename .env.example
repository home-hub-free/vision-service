# vision-service config (copy to .env). Every knob is documented in app/config.py.
# Defaults run the null/CPU build (M0). See DECISIONS.md for what to flip per milestone.

# ── hub (roster + identity broker) ──────────────────────────────────────────
HUB_URL=http://127.0.0.1:8088
# Same secret as server/.env HUB_SERVICE_TOKEN (internal-caller auth for /get-devices,
# /auth/users, /auth/me). Leave blank for an open LAN bring-up.
HUB_SERVICE_TOKEN=

# ── §2 validation escape hatch — pull a NON-declaring source (no firmware) ───
# Comma-list of id@zone@url. The reader auto-selects transport by scheme: http(s):// =
# MJPEG (ESP32-CAM), rtsp:// = H.264 via OpenCV (Reolink/Amcrest/Dahua/Tapo/ONVIF).
# Dual-stream: give two space-separated URLs — `<detect-substream> <record-mainstream>` —
# to run detection on the cheap substream while recording the main stream by codec-copy.
# Augments the roster; the roster wins on id clash. See README "Validation spike".
# VISION_STATIC_CAMERAS=lab@sala@http://192.168.1.50:81/stream
# VISION_STATIC_CAMERAS=patio@garden@rtsp://user:pass@192.168.1.50:554/stream2 rtsp://user:pass@192.168.1.50:554/stream1

# ── RTSP transport (rtsp:// cameras only) ───────────────────────────────────
# TCP is the reliable default (UDP corrupts H.264 on busy Wi-Fi). Needs opencv installed
# (reader) + ffmpeg on PATH (codec-copy recording) — see requirements.txt.
VISION_RTSP_TRANSPORT=tcp
VISION_RTSP_TIMEOUT_S=5

# ── ingestion producer (homehub/<zone>/<cam>/<channel>) ─────────────────────
VISION_INGESTION_ENABLED=true
MQTT_URL=mqtt://127.0.0.1:1883

# ── perception backend (M0=null, M1=ultralytics, M2=insightface) ────────────
VISION_BACKEND=null
VISION_FACE_BACKEND=null
VISION_DETECT_FPS=5
VISION_FACE_THRESHOLD=0.35
# Online reinforcement — LEGACY (anchor-less) members only: enrolled members' profiles
# are immutable anchor sets and never reinforce (every runtime fold into a shared mean
# was a measured pollution channel — 2026-07-07).
VISION_FACE_REINFORCE=true
VISION_FACE_REINFORCE_THRESHOLD=0.5     # must clear this (> match threshold) to reinforce
VISION_FACE_REINFORCE_MARGIN=0.08       # and beat the 2nd-best member by this (no look-alike drift)
VISION_FACE_REINFORCE_CAP=50            # running-mean weight cap → gentle EMA once established
# Identity-grade quality gate (a face below ANY bar abstains from identity; the person
# still counts for occupancy). Size floor applies AFTER the high-res rescue.
# VISION_FACE_MIN_PX=72
# VISION_FACE_MIN_DET_SCORE=0.55
# VISION_FACE_MAX_YAW=45
# VISION_FACE_MAX_PITCH=35
# VISION_FACE_MIN_SHARPNESS=30          # Laplacian var; live median ~220, blur <25
# Enrollment is ground truth → stricter gate + actionable 422s for the guided flow.
# VISION_ENROLL_MIN_PX=110
# VISION_ENROLL_MIN_DET_SCORE=0.65
# VISION_ENROLL_MAX_YAW=30
# VISION_ENROLL_MAX_PITCH=25
# VISION_ENROLL_MIN_SHARPNESS=60
# VISION_FACE_ANCHOR_CAP=60             # newest N enroll anchors kept per member
# Autoheal maturity — never promote a single frame.
# VISION_FACE_AUTOHEAL_MIN_SIGHTINGS=5
# VISION_FACE_AUTOHEAL_MIN_SPAN_S=600
# VISION_FACE_AUTOHEAL_MIN_COHERENCE=0.45
# A promoted cluster only ANSWERS as its member when the LIVE face coheres with the
# member's anchors at least this much (below it → anonymous sighting). Neutralises a
# junk/blurry human confirm and a drifted promotion without re-queuing the card; set
# at the audit detach bar, well under the match threshold so far/angled faces resolve.
# VISION_FACE_PROMOTED_MIN_COHERENCE=0.30
# Scheduled audit + smear alarm (GET /faces/health, POST /faces/audit): freezes all
# silent folds while two member profiles read confusably alike; self-clears. Detaches
# only AUTO-promotions that drift below the bar (never a human "yes it's me").
# VISION_FACE_AUDIT_INTERVAL_S=21600
# VISION_FACE_SMEAR_ALARM_COS=0.45
# VISION_FACE_AUDIT_DETACH_BELOW=0.30
# VISION_FACE_CHURN_WARN_24H=30
# GPU (only with a real backend — watch voice TTFA, §11.1):
# VISION_DEVICE=cuda
# VISION_ORT_PROVIDERS=ROCMExecutionProvider,CPUExecutionProvider

# ── context tiers T0/T1 (VISION_CONTEXT_TIERS_PLAN §2/§3) ────────────────────
# T0 dwell/speed → zone activity (no model, ~0 ms). Thresholds; speed in frame-widths/s.
# VISION_ACTIVITY_PASS_DWELL_S=20
# VISION_ACTIVITY_SETTLE_DWELL_S=60
# VISION_ACTIVITY_SPEED_FWS=0.25
# VISION_DIGEST_HEARTBEAT_S=30          # occupied-zone digest re-push cadence
# T1 posture (yolov8n-pose, same runtime as detect; benched ~13 ms/frame CPU @640).
VISION_POSE_BACKEND=null                # "ultralytics" to enable
# VISION_POSE_EVERY_N=1                 # cost-gate lever: pose every Nth detect frame
# VISION_LYING_OK_ZONES=bedroom,recamara,cuarto,living,sala
# VISION_LYING_ALERT_DWELL_S=60         # lying elsewhere longer than this → posture_alert

# ── recording + retention (§9) ──────────────────────────────────────────────
VISION_REC_MODE=hybrid
VISION_REC_ENCODER=libx264
VISION_RETENTION_DAYS=5
VISION_DISK_CAP_GB=0
